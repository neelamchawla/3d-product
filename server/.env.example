# Server port (Render sets this automatically)
# PORT=8080

# Comma-separated allowed frontend origins for CORS
CLIENT_ORIGIN=http://localhost:5173,https://threejs-product.netlify.app

# Image provider: huggingface (recommended, free) | pollinations (paid) | openai (paid)
IMAGE_PROVIDER=huggingface

# Hugging Face - free token from https://huggingface.co/settings/tokens
# Create a token with "Inference Providers" / "Make calls to Inference Providers" permission
HUGGINGFACE_API_KEY=your-huggingface-token-here
HUGGINGFACE_MODEL=black-forest-labs/FLUX.1-schnell
HUGGINGFACE_PROVIDER=auto

# Pollinations - now requires payment (402)
# IMAGE_PROVIDER=pollinations
# POLLINATIONS_MODEL=flux

# OpenAI - requires billing
# IMAGE_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_IMAGE_MODEL=gpt-image-1
